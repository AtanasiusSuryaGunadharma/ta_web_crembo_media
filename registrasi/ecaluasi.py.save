# evaluasi.py
# Modul evaluasi tugas streaming
# - Membuat tabel 'evaluasi' (SQLite)
# - Blueprint Flask: /evaluasi/<token>  (GET form, POST simpan)
# - Utilitas: generate token evaluasi per tugas, arsip .txt opsional, kirim WA (provider-agnostic)
#
# ENV yang dipakai (opsional):
#   DB_PATH=portal_berita.db
#   BASE_URL=https://www.crembomedia.com
#   WABLAS_URL=https://sby.wablas.com/api/send-message   (atau endpoint WA lain)
#   WABLAS_TOKEN=xxxxx
#   WABLAS_DEVICE_ID=xxxxx   (kalau API butuh)
#
# Cara pakai:
#   1) Di app.py: from evaluasi import evaluasi_bp, init_db
#                  init_db()  # sekali saat startup
#                  app.register_blueprint(evaluasi_bp)
#
#   2) Generate token dari kode lain (mis. scheduler):
#         from evaluasi import ensure_evaluasi_row
#         token = ensure_evaluasi_row(tanggal="2025-09-01", misa_id="MISA-PAGI", operator_name="Budi")
#         link = f"{BASE_URL}/evaluasi/{token}"
#
#   3) CLI opsional:
#         python3 evaluasi.py --init-db
#         python3 evaluasi.py --new-link --tanggal 2025-09-01 --misa-id MISA-PAGI --operator "Budi"
#         python3 evaluasi.py --send-wa --phone 62812xxxx --message "teks"
#
#   4) Opsional arsip .txt: set ENABLE_ARCHIVE_TXT=True di bawah.

import os
import sqlite3
import secrets
import datetime
from typing import Optional, Dict

try:
    import requests  # hanya diperlukan bila pakai fungsi send_wa
except Exception:
    requests = None

from flask import Blueprint, request, render_template_string, abort

# ===================== Konfigurasi =====================
DB_PATH = os.environ.get("DB_PATH", "crembo.db")
BASE_URL = os.environ.get("BASE_URL", "https://crembomedia.com")

WABLAS_URL = os.environ.get("WABLAS_URL", "https://sby.wablas.com/api/send-message")
WABLAS_TOKEN = os.environ.get("WABLAS_TOKEN", "")
WABLAS_DEVICE_ID = os.environ.get("WABLAS_DEVICE_ID", "")

ENABLE_ARCHIVE_TXT = False               # ubah ke True kalau ingin arsip .txt
ARCHIVE_DIR = "/var/log/evaluasi"        # folder arsip .txt

evaluasi_bp = Blueprint("evaluasi", __name__)

# ===================== HTML Form =====================

FORM_HTML = """
<!doctype html><meta charset="utf-8">
<title>Evaluasi Tugas</title>
<style>
  :root { color-scheme: light dark; }
  body { font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif; margin: 24px; max-width: 820px; }
  h2 { margin-bottom: 4px; }
  .muted { color: #666; font-size: .92rem; margin-bottom: 14px; }
  label { font-weight: 600; display:block; margin-top: 12px; }
  textarea, input[type=text] { width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #ccc; }
  .row { display:grid; grid-template-columns: 1fr 1fr; gap: 12px; }
